# Self-hosted GitHub Actions runner config (for docker-compose.runner.yml)
# Copy to .env.runner on the NAS and fill in your token:
#   cp runner.env.example .env.runner
#
# GH_ACCESS_TOKEN: classic Personal Access Token with "repo" scope,
# created at https://github.com/settings/tokens
# Used only to auto-register/renew the runner — never committed.
GH_ACCESS_TOKEN=
