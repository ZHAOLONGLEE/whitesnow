# WhiteSnow Environment Variables
# Copy to .env and fill in your values

# App
APP_ENV=development
APP_SECRET=change-me-to-a-random-string

# Server (your public IP)
PUBLIC_IP=159.195.38.110

# NAS Media Library (host path to your media directory)
MEDIA_ROOT=/path/to/your/nas/media
MEDIA_MOUNT=/media

# Database
DATABASE_URL=sqlite:///./data/mediascan.db

# Server
HOST=0.0.0.0
PORT=8000

# Admin (optional, for future user system)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Metadata Scraping (CSPT Douban Proxy)
DOUBAN_API_URL=https://cspt.top/api/ptgen/query/<token>
DOUBAN_API_TOKEN=<your_token>
